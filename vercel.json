{
  "cleanUrls": true,
  "trailingSlash": false,
  "redirects": [
    {
      "source": "/index.html",
      "destination": "/",
      "statusCode": 308
    },
    {
      "source": "/(.*)",
      "has": [
        {
          "type": "host",
          "value": "www.cgpacalculator.dev"
        }
      ],
      "destination": "https://cgpacalculator.dev/$1",
      "statusCode": 308
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        }
      ]
    }
  ]
}
